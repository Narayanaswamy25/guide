generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  password       String
  name           String?
  role           String   @default("student")
  selectedDegree String?
  
  // Credentials
  age            Int?
  gender         String?
  dob            String?

  // Survey fields (Academic Profile)
  educationLevel     String?
  stream             String?
  subjects           String? // Comma-separated
  careerInterests    String? // Comma-separated
  mainGoal           String?
  learningStyle      String? // Comma-separated
  studyLocation      String?
  budgetPreference   String?
  degreeAwareness    String? // Comma-separated
  confusionLevel     String?
  excitementFactor   String?
  personalityTrigger String?
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tasks          Task[]
  habits         Habit[]

  @@map("users")
}

model Task {
  id          String     @id @default(uuid())
  title       String
  description String?
  status      TaskStatus @default(TODO)
  priority    String     @default("medium")
  dueDate     DateTime?
  userId      String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tasks")
}

model Habit {
  id             String   @id @default(uuid())
  name           String
  streak         Int      @default(0)
  completedToday Boolean  @default(false)
  userId         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("habits")
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  DONE
  CANCELED
}
