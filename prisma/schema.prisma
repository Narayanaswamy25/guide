generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./guide.db"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name           String?
  role           String   @default("student")
  selectedDegree String?
  avatar         String?
  bio            String?
  github         String?
  twitter        String?
  linkedin       String?
  focusHours     Int      @default(0)
  
  // Credentials
  age            Int?
  gender         String?
  dob            String?

  // Survey fields (Academic Profile)
  educationLevel     String?
  stream             String?
  subjects           String? // Comma-separated
  careerInterests    String? // Comma-separated
  mainGoal           String?
  learningStyle      String? // Comma-separated
  studyLocation      String?
  budgetPreference   String?
  degreeAwareness    String? // Comma-separated
  confusionLevel     String?
  excitementFactor   String?
  personalityTrigger String?
  
  createdAt      DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks     Task[]
  habits    Habit[]
  courses   Course[]
  roadmapModules RoadmapModule[]
  academicRecord AcademicRecord?

  @@map("users")
}

model Task {
  id          String     @id @default(uuid())
  title       String
  description String?
  status      String     @default("TODO")
  priority    String     @default("medium")
  dueDate     DateTime?
  userId      String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tasks")
}

model Habit {
  id             String   @id @default(uuid())
  name           String
  streak         Int      @default(0)
  completedToday Boolean  @default(false)
  userId         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("habits")
}

model Course {
  id           String   @id @default(uuid())
  code         String
  title        String
  instructor   String
  category     String
  color        String
  status       String   @default("active") // active, completed, upcoming
  progress     Int      @default(0)
  grade        String?
  nextDeadline String?
  userId       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("courses")
}

model RoadmapModule {
  id        String   @id @default(uuid())
  degreeId  String
  domainId  String
  moduleIdx Int
  userId    String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, degreeId, domainId, moduleIdx])
  @@map("roadmap_modules")
}

model AcademicRecord {
  id              String   @id @default(uuid())
  gpa             Float    @default(0.0)
  creditsEarned   Int      @default(0)
  creditsRequired Int      @default(120)
  userId          String   @unique
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("academic_records")
}


